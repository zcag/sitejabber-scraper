{
    "actorSpecification": 1,
    "name": "sitejabber-review-scraper",
    "title": "SiteJabber Reviews Scraper API | $1.00/1K Reviews",
    "description": "Scrape SiteJabber (SmartCustomer) reviews, ratings, and company profiles. Extract recommendation rates, verification status, star distributions, and structured review data. Lightweight CheerioCrawler — no browser needed. $1.00 per 1,000 reviews.",
    "version": "0.1",
    "buildTag": "latest",
    "dockerfile": "../Dockerfile",
    "input": "./input_schema.json",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "title": "SiteJabber Reviews",
            "views": {
                "reviews": {
                    "title": "Reviews",
                    "transformation": {
                        "fields": [
                            "companyName",
                            "rating",
                            "reviewTitle",
                            "reviewText",
                            "authorName",
                            "publishedDate",
                            "isVerified",
                            "reviewUrl"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "rating": { "label": "Stars", "format": "number" },
                            "publishedDate": { "label": "Date", "format": "text" }
                        }
                    }
                }
            }
        }
    }
}
